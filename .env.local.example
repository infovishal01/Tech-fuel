# ==========================================
# Tech Fuel - Environment Variables Configuration
# ==========================================

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# MongoDB Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Production MongoDB Atlas connection:
MONGODB_URI=mongodb+srv://infovishalkumar01_db_user:FACNXr7epX4ZqPsu@cluster0.n1no7sj.mongodb.net/tech-fuel

# ------------------------------------------
# Authentication Configuration
# ------------------------------------------
# JWT Secret for token generation (minimum 32 characters)
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# NextAuth.js Configuration
NEXTAUTH_SECRET=your_nextauth_secret_here_minimum_32_characters
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ------------------------------------------
# AI Configuration (OpenAI)
# ------------------------------------------
# OpenAI API Key
OPENAI_API_KEY=sk-your_openai_api_key_here

# AI Model Configuration
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_STREAMING=true

# AI Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=100
AI_RATE_LIMIT_PER_HOUR=1000

# ------------------------------------------
# Application Configuration
# ------------------------------------------
# Node Environment
NODE_ENV=development

# Application Port
PORT=3000

# Session Configuration
SESSION_SECRET=your_session_secret_here_minimum_32_characters

# ------------------------------------------
# Code Execution Configuration (For Backend Examples)
# ------------------------------------------
# Enable code execution (false for production without sandbox)
CODE_EXECUTION_ENABLED=false

# Code execution timeout in milliseconds
CODE_EXECUTION_TIMEOUT=5000

# Supported languages for code execution
CODE_EXECUTION_LANGUAGES=javascript,python,java

# ------------------------------------------
# File Upload Configuration
# ------------------------------------------
# Maximum file upload size in bytes (10MB)
MAX_FILE_SIZE=10485760

# Allowed file types for uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# File upload directory
UPLOAD_DIR=./public/uploads

# ------------------------------------------
# Email Configuration (For Notifications)
# ------------------------------------------
# Email provider (nodemailer, sendgrid, etc.)
EMAIL_PROVIDER=nodemailer

# SMTP Configuration (for nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password_here

# Default sender email
EMAIL_FROM=no-reply@techfuel.dev

# ------------------------------------------
# Analytics & Monitoring
# ------------------------------------------
# Google Analytics ID (Optional)
GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (Optional)
SENTRY_DSN=your_sentry_dsn_here

# ------------------------------------------
# CORS Configuration
# ------------------------------------------
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ------------------------------------------
# Rate Limiting Configuration
# ------------------------------------------
# API rate limit per minute
API_RATE_LIMIT_PER_MINUTE=100

# API rate limit per hour
API_RATE_LIMIT_PER_HOUR=1000

# ------------------------------------------
# Security Configuration
# ------------------------------------------
# Content Security Policy
CSP_DIRECTIVE=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:

# X-Frame-Options
X_FRAME_OPTIONS=SAMEORIGIN

# X-Content-Type-Options
X_CONTENT_TYPE_OPTIONS=nosniff

# ------------------------------------------
# Cache Configuration
# ------------------------------------------
# Redis URL for caching (Optional)
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
CACHE_TTL=3600

# Session cache TTL in seconds
SESSION_CACHE_TTL=86400

# ==========================================
# Development Environment (Override for production)
# ==========================================

# For development, you can use:
# MONGODB_URI=mongodb://localhost:27017/tech-fuel-dev
# NEXTAUTH_URL=http://localhost:3000
# NODE_ENV=development

# For production, use:
# MONGODB_URI=mongodb+srv://infovishalkumar01_db_user:FACNXr7epX4ZqPsu@cluster0.n1no7sj.mongodb.net/tech-fuel
# NEXTAUTH_URL=https://tech-fuel.vercel.app
# NODE_ENV=production

# ===========================================
